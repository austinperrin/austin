{
  "name": "poke-the-austin",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A desktop-only Phaser webgame where the cursor duels 16-bit Austin.",
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "dev": "pnpm --filter @poke-the-austin/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @poke-the-austin/web test:e2e",
    "format": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.46.3"
  }
}
